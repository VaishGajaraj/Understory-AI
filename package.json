{
  "name": "understory-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Understory monorepo — TypeScript workspaces",
  "license": "Apache-2.0",
  "workspaces": ["apps/*", "packages/typescript-config"],
  "engines": {
    "node": ">=22"
  },
  "packageManager": "bun@1.3.14",
  "scripts": {
    "fmt": "biome check --write .",
    "lint": "biome check .",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun test",
    "build": "bun run --filter '*' build"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "typescript": "^5.7.0"
  }
}
